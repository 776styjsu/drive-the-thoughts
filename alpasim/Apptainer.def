# Apptainer definition file for AlpaSim
#
# Self-contained build — no Docker daemon required.
#
# Usage:
#   ./build_apptainer.sh
#
# Or manually:
#   apptainer build --bind $HOME/.netrc:/run/netrc:ro alpasim_base_latest.sif Apptainer.def

Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

%files
    . /repo

%post
    # ---- System packages ----
    apt-get update && apt-get install -y \
        git \
        ffmpeg \
        curl \
        && rm -rf /var/lib/apt/lists/*

    # ---- Install uv ----
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    # ---- Handle .netrc for private-repo access ----
    # The host's .netrc is bind-mounted read-only at /run/netrc during build.
    # Copy it in temporarily so uv/git can authenticate.
    NETRC_TMP=""
    if [ -f /run/netrc ]; then
        cp /run/netrc /root/.netrc
        chmod 600 /root/.netrc
        NETRC_TMP="yes"
    fi

    # ---- Remove stale host .venv dirs (copied by %files, have broken paths) ----
    find /repo -name ".venv" -type d -exec rm -rf {} + 2>/dev/null || true

    # ---- Compile protos ----
    cd /repo/src/grpc
    NETRC=/root/.netrc uv sync
    uv run compile-protos --no-sync

    # ---- Full project sync ----
    cd /repo
    NETRC=/root/.netrc uv sync --all-packages

    # ---- Ensure plugin package is importable at runtime ----
    # Driver imports `alpasim_plugins` directly; install it into /repo/.venv
    # so `uv run` in containers can resolve it without extra PYTHONPATH hacks.
    NETRC=/root/.netrc UV_PROJECT_ENVIRONMENT=/repo/.venv \
        uv pip install -e /repo/src/plugins

    # ---- Patch torchvision av collision ----
    # maglev.av has name collisions with PyAV (both use `import av`).
    # Patch torchvision to trigger its "av not available" fallback path.
    for f in .venv/lib/python*/site-packages/torchvision/io/video.py \
             .venv/lib/python*/site-packages/torchvision/io/video_reader.py; do
        [ -f "$f" ] && sed -i 's/import av$/raise ImportError("maglev.av collision")/' "$f"
    done || true

    # ---- Remove temporary .netrc (do NOT bake credentials into image) ----
    if [ -n "$NETRC_TMP" ]; then
        rm -f /root/.netrc
    fi

%environment
    export UV_CACHE_DIR=/tmp/uv-cache
    export UV_NO_SYNC=1
    export UV_LINK_MODE=copy
    export PATH="/root/.local/bin:$PATH"

%runscript
    exec uv run python "$@"

%labels
    Author NVIDIA AlpaSim Team
    Description AlpaSim simulation container (Apptainer, self-contained build)

%help
    AlpaSim simulation container — built entirely with Apptainer (no Docker).
    Supports GPU passthrough via --nv flag.

    Example usage:
        apptainer exec --nv --bind data:/mnt/data alpasim_base_latest.sif \
            bash -c "uv run python -m alpasim_controller.server"
